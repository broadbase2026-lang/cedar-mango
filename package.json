{
  "name": "broadbase",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "env -u HTTP_PROXY -u HTTPS_PROXY -u ALL_PROXY -u http_proxy -u https_proxy -u all_proxy NODE_OPTIONS=--dns-result-order=ipv4first WATCHPACK_POLLING=true WATCHPACK_POLLING_INTERVAL=1000 next dev",
    "dev:clean": "rm -rf .next node_modules/.cache && env -u HTTP_PROXY -u HTTPS_PROXY -u ALL_PROXY -u http_proxy -u https_proxy -u all_proxy NODE_OPTIONS=--dns-result-order=ipv4first WATCHPACK_POLLING=true WATCHPACK_POLLING_INTERVAL=1000 next dev",
    "build": "next build && node scripts/copy-main-css.mjs",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "favicons": "node scripts/generate-favicon.mjs",
    "import-mbox": "tsx scripts/mbox-import/run.ts",
    "rollback-mbox": "tsx scripts/mbox-import/rollback-manifest.ts",
    "purge-mbox-brands": "tsx scripts/mbox-import/rollback-manifest.ts --purge-brands"
  },
  "dependencies": {
    "@google-cloud/vertexai": "^1.12.0",
    "@google/generative-ai": "^0.24.1",
    "@radix-ui/react-dialog": "^1.1.15",
