    "@supabase/supabase-js": "^2.106.2",
    "@tiptap/extension-color": "^3.22.5",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/extension-text-style": "^3.22.5",
    "@tiptap/extension-underline": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "axios": "^1.16.1",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "jsonrepair": "^3.13.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.14.0",
    "mammoth": "^1.10.0",
    "motion": "^12.40.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^6.12.4",
    "sanitize-html": "^2.17.3",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "stripe": "^22.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/sanitize-html": "^2.16.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "@types/mailparser": "^3.4.6",
    "mailparser": "^3.9.0",
    "tsx": "^4.20.3",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  },
  "description": "",
