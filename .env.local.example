# Supabase
NEXT_PUBLIC_SUPABASE_URL=           # Project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=      # Anon key — safe to expose
SUPABASE_SERVICE_ROLE_KEY=          # Service role — server only

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY= # Safe to expose
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=              # From Stripe dashboard
# Customer Portal: enable in Stripe Dashboard → Settings → Billing → Customer portal (used by /api/stripe/billing-portal)
STRIPE_STARTER_PRICE_ID=            # HK$780/mo
STRIPE_PRO_PRICE_ID=                # HK$2,340/mo
STRIPE_AGENCY_PRICE_ID=             # HK$6,240/mo

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=                  # e.g. digest@broadbase.app
RESEND_WEBHOOK_SECRET=              # Svix signing secret from Resend webhook settings

# Google Cloud / Vertex AI — server only; uses Application Default Credentials (gcloud auth application-default login)
GOOGLE_CLOUD_PROJECT=              # GCP project ID (or GCP_PROJECT)
GOOGLE_CLOUD_LOCATION=             # e.g. us-central1 (optional; default us-central1)

# Google Gemini API (Generative AI) — server only; powers AI Readiness + Journalist Research Assistant
GEMINI_API_KEY=
# Optional overrides (defaults: gemini-2.0-flash / gemini-2.0-pro)
# GEMINI_MODEL_FLASH=
# GEMINI_MODEL_PRO=

# Internal
NEXT_PUBLIC_APP_URL=                # e.g. https://broadbase.app
CRON_SECRET=                        # Bearer token for /api/cron/journalist-deletion (and future digest cron)

# Beta (production staged beta on broadbase.app)
BETA_TRIAL_ONLY=true                # Disable paid Stripe checkout; trial-only access
BETA_INVITE_CODE=                   # Require matching code at signup (invite-only beta)
